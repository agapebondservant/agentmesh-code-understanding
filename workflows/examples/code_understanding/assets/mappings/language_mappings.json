{
  "pygments_mappings": {
    "bash":             "shell",
    "transact-sql":     "sql",
    "java server page": "jsp",
    "django/jinja":     "jinja2",
    "html+handlebars":  "handlebars",
    "html+twig":        "twig",
    "java":             "java",
    "python":           "python",
    "c++":              "c++",
    "c":                "c",
    "javascript":       "javascript",
    "sql":              "sql",
    "ruby":             "ruby",
    "shell":            "shell",
    "ansible":          "ansible",
    "terraform":        "terraform",
    "cloudformation":   "cloudformation",
    "puppet":           "puppet",
    "jsp":              "jsp",
    "freemarker":       "freemarker",
    "velocity":         "velocity",
    "xslt":             "xslt",
    "django":           "django",
    "jinja2":           "jinja2",
    "handlebars":       "handlebars",
    "pug":              "pug",
    "ejs":              "ejs",
    "nunjucks":         "nunjucks",
    "mustache":         "mustache",
    "erb":              "erb",
    "liquid":           "liquid",
    "twig":             "twig",
    "blade":            "blade"
  },

  "file_extensions": {
    "java":           [".java", ".kt"],
    "python":         [".py", ".pyi"],
    "c++":            [".c", ".h", ".i", ".C", ".cpp", ".cc", ".cxx"],
    "c":              [".c", ".h", ".i", ".C", ".cpp", ".cc", ".cxx"],
    "javascript":     [".js", ".ts"],
    "sql":            [".sql"],
    "ruby":           [".rb"],
    "shell":          [".sh"],
    "ansible":        [".yaml", ".yml"],
    "terraform":      [".tf", ".tfvars"],
    "cloudformation": [".yaml", ".yml", ".json", ".template"],
    "puppet":         [".pp", ".epp"],
    "jsp":            [".jsp"],
    "freemarker":     [".ftl", ".ftlh"],
    "velocity":       [".vm", ".vtl"],
    "xslt":           [".xsl", ".xslt"],
    "django":         [".html", ".htm"],
    "jinja2":         [".j2", ".jinja", ".jinja2"],
    "handlebars":     [".hbs", ".handlebars"],
    "pug":            [".pug", ".jade"],
    "ejs":            [".ejs"],
    "nunjucks":       [".njk"],
    "mustache":       [".mustache"],
    "erb":            [".erb"],
    "liquid":         [".liquid"],
    "twig":           [".twig"],
    "blade":          [".blade.php"]
  },

  "config_file_extensions": {
    "java":           [".xml", ".gradle", ".properties", ".yaml", ".yml", ".json"],
    "python":         [".cfg", ".toml", ".ini", ".txt"],
    "c++":            [".cmake", ".mk"],
    "c":              [".cmake", ".mk"],
    "javascript":     [".json", ".yaml", ".yml"],
    "typescript":     [".json", ".yaml", ".yml"],
    "sql":            [".yaml", ".yml", ".json", ".ini"],
    "ruby":           [".gemspec", ".yaml", ".yml"],
    "shell":          [".env", ".conf", ".cfg"],
    "ansible":        [".cfg", ".ini", ".yaml", ".yml"],
    "terraform":      [".tfvars", ".json"],
    "cloudformation": [".yaml", ".yml", ".json"],
    "puppet":         [".yaml", ".yml", ".json"],
    "jsp":            [".xml", ".properties"],
    "freemarker":     [".xml", ".properties"],
    "velocity":       [".properties", ".xml"],
    "xslt":           [".xml"],
    "django":         [".env", ".cfg", ".ini"],
    "jinja2":         [".cfg", ".ini", ".toml"],
    "handlebars":     [".json"],
    "pug":            [".json"],
    "ejs":            [".json"],
    "nunjucks":       [".json", ".yaml", ".yml"],
    "mustache":       [".json"],
    "erb":            [".yaml", ".yml"],
    "liquid":         [".yaml", ".yml", ".json"],
    "twig":           [".yaml", ".yml", ".xml"],
    "blade":          [".env", ".json"]
  },

  "comment_delimiters_by_extension": {
    ".xml":        ["<!--", "-->"],
    ".gradle":     ["/*", "*/"],
    ".properties": ["#", ""],
    ".yaml":       ["#", ""],
    ".yml":        ["#", ""],
    ".json":       ["/*", "*/"],
    ".cfg":        ["#", ""],
    ".toml":       ["#", ""],
    ".ini":        ["#", ""],
    ".txt":        ["#", ""],
    ".cmake":      ["#", ""],
    ".mk":         ["#", ""],
    ".gemspec":    ["#", ""],
    ".env":        ["#", ""],
    ".conf":       ["#", ""]
  },

  "exclude_dirs": {
    "java":           ["vendor", "node_modules", ".git", "bower_components", "target", ".gradle"],
    "python":         ["vendor", "node_modules", ".git", "__pycache__", ".venv", "dist", "build"],
    "javascript":     ["vendor", "node_modules", ".git", "bower_components", "dist", "build", "coverage"],
    "sql":            ["vendor", "node_modules", ".git"],
    "shell":          ["vendor", "node_modules", ".git"],
    "ruby":           ["vendor", "node_modules", ".git", ".bundle"],
    "c++":            ["vendor", "node_modules", ".git", "build", "cmake-build-debug"],
    "c":              ["vendor", "node_modules", ".git", "build", "cmake-build-debug"],
    "ansible":        ["vendor", "node_modules", ".git"],
    "terraform":      ["vendor", "node_modules", ".git", ".terraform"],
    "cloudformation": ["vendor", "node_modules", ".git"],
    "puppet":         ["vendor", "node_modules", ".git"],
    "jsp":            ["vendor", "node_modules", ".git", "target", "build"],
    "freemarker":     ["vendor", "node_modules", ".git", "target", "build"],
    "velocity":       ["vendor", "node_modules", ".git", "target", "build"],
    "xslt":           ["vendor", "node_modules", ".git"],
    "django":         ["vendor", "node_modules", ".git", "__pycache__", ".venv", "dist", "build"],
    "jinja2":         ["vendor", "node_modules", ".git", "__pycache__", ".venv"],
    "handlebars":     ["vendor", "node_modules", ".git", "dist", "build"],
    "pug":            ["vendor", "node_modules", ".git", "dist", "build"],
    "ejs":            ["vendor", "node_modules", ".git", "dist", "build"],
    "nunjucks":       ["vendor", "node_modules", ".git", "dist", "build"],
    "mustache":       ["vendor", "node_modules", ".git", "dist", "build"],
    "erb":            ["vendor", "node_modules", ".git", ".bundle"],
    "liquid":         ["vendor", "node_modules", ".git", "_site"],
    "twig":           ["vendor", "node_modules", ".git", "var", "cache"],
    "blade":          ["vendor", "node_modules", ".git", "storage", "bootstrap"]
  },

  "comment_delimiters_by_language": {
    "java":           ["/*", "*/"],
    "python":         ["\"\"\"", "\"\"\""],
    "c++":            ["/*", "*/"],
    "c":              ["/*", "*/"],
    "javascript":     ["/*", "*/"],
    "sql":            ["/*", "*/"],
    "ruby":           ["=begin", "=end"],
    "shell":          ["<< 'COMMENT'", "COMMENT"],
    "ansible":        ["#", ""],
    "terraform":      ["#", ""],
    "cloudformation": ["#", ""],
    "puppet":         ["#", ""],
    "jsp":            ["<%--", "--%>"],
    "freemarker":     ["<#--", "-->"],
    "velocity":       ["#*", "*#"],
    "xslt":           ["<!--", "-->"],
    "django":         ["{% comment %}", "{% endcomment %}"],
    "jinja2":         ["{#", "#}"],
    "handlebars":     ["{{!--", "--}}"],
    "pug":            ["//", ""],
    "ejs":            ["<%#", "%>"],
    "nunjucks":       ["{#", "#}"],
    "mustache":       ["{{!", "}}"],
    "erb":            ["<%#", "%>"],
    "liquid":         ["{% comment %}", "{% endcomment %}"],
    "twig":           ["{#", "#}"],
    "blade":          ["{{--", "--}}"]
  }
}
