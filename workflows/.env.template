# Object Storage
AWS_S3_ENDPOINT=<minio service endpoint>
AWS_ACCESS_KEY_ID=<minio service username>
AWS_SECRET_ACCESS_KEY=<minio service password>
AWS_S3_BUCKET=data

# Access Tokens
CODEAGENT_GIT_PAT=<Git Personal Access Token>

# Agent LLMs
GRAPHRAG_LLM_TOKEN=<graphrag llm token>
GRAPHRAG_LLM_ID=<graphrag llm model name>
GRAPHRAG_LLM_API_BASE=<graphrag llm api base>
GRAPHRAG_LLM_PROVIDER=<graphrag llm provider>
GRAPHRAG_LLM_PROVIDER_GRAPHRAG=<graphrag llm provider for graphrag>
GRAPHRAG_LLM_THINKING=<whether thinking mode exists and is enabled>
EMBED_LLM_TOKEN=<embed llm token>
EMBED_LLM_API_BASE=<embed llm api base>
EMBED_LLM_ID=<embed llm id>
EMBED_LLM_PROVIDER=<embed llm provider>
EMBED_LLM_PROVIDER_GRAPHRAG=<embed llm provider for graphrag>
EMBED_LLM_THINKING=<whether thinking mode exists and is enabled>
CODE_LLM_TOKEN=<code llm token>
CODE_LLM_API_BASE=<code llm api base>
CODE_LLM_ID=<code llm provider>
CODE_LLM_PROVIDER=<code llm provider>
CODE_LLM_THINKING=<whether thinking mode exists and is enabled>
FALLBACK_LLM_KEY_NAME=HOSTED_VLLM_API_KEY

# Devspaces
DEVSPACES_GIT_REPO=<devspaces git repo>
DEVSPACES_GIT_BRANCH=<devspaces git branch>

# Kubeflow Pipelines
KFP_NAMESPACE=<name of data science project>
KFP_DATA_GENERATION_OUTPUT_PATH=target
KFP_DATA_INDEXING_OUTPUT_PATH=graphrag-source/output
KFP_IMAGE_REGISTRY=<image registry used for kfp pipelines>
KFP_DATA_GENERATION_BASE_IMAGE_NAME=<container image for data generation pipeline components>
KFP_DATA_GENERATION_BASE_IMAGE_VERSION=<container image for data generation pipeline components>
KFP_INDEXING_BASE_IMAGE_NAME=<container image for indexing pipeline components>
KFP_ANALYSIS_BASE_IMAGE_VERSION=<container image for analysis pipeline components>

# Mlflow
MLFLOW_TRACKING_URI=<mlflow tracking server URL>

# Asset Loader
ASSET_LOADER=<local or mlflow>
